# Copy to .env.deploy (gitignored) for local deploys, or set the same variables in CI / your shell.

# --- Client build (required unless you export VITE_API_URL in the environment) ---

# Full API base URL (no trailing slash). Overrides computed workers.dev URL.
# VITE_API_URL=https://healing-practice-api.your-subdomain.workers.dev

# Or set only the workers.dev account label; deploy script picks the worker name for production vs staging.
# CLOUDFLARE_WORKERS_DEV_SUBDOMAIN=your-subdomain

# Optional alias for VITE_API_URL
# DEPLOY_API_URL=https://healing-practice-api.your-subdomain.workers.dev
