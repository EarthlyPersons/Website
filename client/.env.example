# Optional: deployed API base URL (e.g. https://healing-practice-api.<subdomain>.workers.dev)
# Leave unset in local dev to use the Vite proxy at /api → http://localhost:8787
VITE_API_URL=

# Optional: override the dev proxy target (defaults to http://127.0.0.1:8787)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8787
